0BF1EC 01                	format_data:	db	1		; Format flag (1 = update default length)
0BF1ED                   		endl				; End local scope
0BF1ED                   	; ============================================================
0BF1ED                   	; init1 - Reset part playback state (counter reset)
0BF1ED                   	; ============================================================
