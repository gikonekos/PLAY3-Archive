000000                   	; ============================================================
000000                   	; PLAY3 - SHARP PC-E500 3-voice buzzer music driver
000000                   	; Published in Pocket Computer Journal 1993  Author: Ryu
000000                   	; English-commented source (based on play3_pushu.asm)
000000                   	; ============================================================
000000                   		pre_on				; Assembler pre-processing directive
000000                   	; --- System entry points ---
000000                   	fcs:		equ	0fffe4h		; File Control System entry
000000                   	iocs:		equ	0fffe8h		; I/O Control System entry
000000                   	; --- Interrupt vector addresses ---
000000                   	vect0:		equ	0bfcc6h		; Interrupt vector 0
000000                   	vect1:		equ	0bfcc9h		; Interrupt vector 1
000000                   	vect2:		equ	0bfccch		; Interrupt vector 2
000000                   	vect3:		equ	0bfccfh		; Interrupt vector 3
000000                   	vect4:		equ	0bfcd2h		; Interrupt vector 4
000000                   	vect5:		equ	0bfcd5h		; Interrupt vector 5
000000                   	vect6:		equ	0bfcd8h		; Interrupt vector 6
000000                   	vect7:		equ	0bfcdbh		; Interrupt vector 7
000000                   	; --- Internal RAM register alias definitions ---
000000                   	bx:		equ	0d4h		; BX register address
000000                   	bh:		equ	0d5h		; BH register address
000000                   	cx:		equ	0d6h		; CX register address
000000                   	ch:		equ	0d7h		; CH register address
000000                   	dx:		equ	0d8h		; DX register address
000000                   	dh:		equ	0d9h		; DH register address
000000                   	si:		equ	0dah		; SI register address
000000                   	di:		equ	0ddh		; DI register address
000000                   	; --- Pointer registers ---
000000                   	abp:		equ	0ech		; ABP pointer
000000                   	apx:		equ	0edh		; APX pointer
000000                   	apy:		equ	0eeh		; APY pointer
000000                   	; --- Interrupt control registers ---
000000                   	iisr:		equ	0ebh		; Interrupt service register
000000                   	imr:		equ	0fbh		; Interrupt mask register
000000                   	isr:		equ	0fch		; Interrupt status register
000000                   	; --- Hardware registers / BASIC workspace ---
000000                   	beep:		equ	0fdh		; Buzzer control register
000000                   	basic_work:	equ	0d1h		; BASIC workspace base address
000000                   	cr:		equ	00dh		; Carriage return character code
000000                   	; --- Part data structure offset definitions ---
000000                   	part_c:		equ	0		; Part counter (zero-page work area)
000000                   	data_adr:	equ	0		; Current data address offset
000000                   	data_s_adr:	equ	data_adr+3	; Start data address offset
000000                   	oct:		equ	data_s_adr+3	; Octave value offset
000000                   	onp:		equ	oct+1		; Note code offset
000000                   	l_count:	equ	onp+1		; Length counter offset
000000                   	o_count:	equ	l_count+1	; Pitch counter offset
000000                   	; --- MML parser internal RAM constants ---
000000                   	oct_flg:	equ	13h		; Temporary octave change flag address
000000                   	octerve_adr:	equ	30h		; Octave data pointer storage address
000000                   	length_adr:	equ	33h		; Note length data pointer storage address
000000                   	e_flg:		equ	18h		; End flag address
0BF000                   		org	0bf000h			; Load address: 0BF000h
0BF000                   	; ============================================================
0BF000                   	; install / remove - BASIC command registration and removal
0BF000                   	; ============================================================
0BF000                   	install:	local			; Begin local scope
0BF000 0C 26 F0 0B       		mv	x,basic_command		; Command table start address -> X
0BF004 30 BC 80 D1 90    		mv	[(!basic_work)+90h],x	; Register in BASIC command table pointer
0BF009 0C 35 F0 0B       		mv	x,basic_code		; Command code table address -> X
0BF00D 30 BC 80 D1 93    		mv	[(!basic_work)+93h],x	; Register in BASIC code table pointer
0BF012 07                		retf				; Far return
0BF013 0C FF FF 0F       	remove:		mv	x,0fffffh	; Invalid address (for command removal)
0BF017 30 BC 80 D1 90    		mv	[(!basic_work)+90h],x	; Clear command table pointer
0BF01C 30 BC 80 D1 93    		mv	[(!basic_work)+93h],x	; Clear code table pointer
0BF021 05 EF F1 0B       		callf	!init1			; Initialize playback state
0BF025 07                		retf				; Far return
0BF026                   	; ============================================================
0BF026                   	; BASIC command table definition
0BF026                   	; Registers PLAY command and EXOFF command
0BF026                   	; ============================================================
0BF026 04                	basic_command:	db	04h		; Number of command characters (4)
0BF027 50 4C 41 59       		dm	'PLAY'			; Command name string
0BF02B 1F                		db	1fh			; Intermediate code
0BF02C 05                		db	5			; Next command character count (5)
0BF02D 45 58 4F 46 46    		dm	'EXOFF'			; Command name string
0BF032 02                		db	2			; Code length
0BF033 00 00             		db	0,0			; Terminator
0BF035 1F                	basic_code:	db	1fh		; Code flag
0BF036 3F F0             		dw	!entry			; PLAY command handler address
0BF038 8B                		db	8bh			; Attribute byte (bit6=1, bit7=1)
0BF039 02                		db	2			; Code length
0BF03A 13 F0             		dw	remove			; EXOFF command handler address
0BF03C 8B                		db	8bh			; Attribute byte
0BF03D 00 00             		db	0,0			; Terminator
0BF03F                   		endl				; End local scope
0BF03F                   	; ============================================================
0BF03F                   	; entry - PLAY command entry point
0BF03F                   	; Disables interrupts, runs MML parsing/playback, then restores state
0BF03F                   	; ============================================================
0BF03F                   	entry:		local			; Begin local scope
0BF03F 2F                		pushu imr			; Save interrupt mask register onto stack
0BF040 30 CC FB A0       		mv	(!imr),0a0h		; Set interrupt mask (disable all but timer)
0BF044 30 E8 36 EC       		mv	[--u],(!abp)		; Save ABP pointer onto stack
0BF048 04 57 F0          		call	mml_conv		; Call MML string parsing routine
0BF04B 2C                		pushu	x			; Save X register
0BF04C 05 0E F2 0B       		callf	!init2			; Call playback init and main loop
0BF050 3C                		popu	x			; Restore X register
0BF051 30 E0 26 EC       		mv	(!abp),[u++]		; Restore ABP pointer
0BF055 3F                		popu imr			; Restore interrupt mask register
0BF056 07                		retf				; Far return (back to BASIC)
0BF057                   	; ============================================================
0BF057                   	; mml_conv - MML string parsing routine
0BF057                   	; X: MML string pointer
0BF057                   	; Parses the MML string and builds playback data buffers for each part
0BF057                   	; ============================================================
0BF057 0D E3 F1 0B       	mml_conv:	mv	y,octerve	; Default octave data address -> Y
0BF05B 30 A5 30          		mv	(!octerve_adr),y	; Store octave pointer in internal RAM
0BF05E 0D E4 F1 0B       		mv	y,length		; Default note length data address -> Y
0BF062 30 A5 33          		mv	(!length_adr),y		; Store length pointer in internal RAM
0BF065 0D 29 F5 0B       		mv	y,!part1+!data_s_adr	; Part 1 data start address -> Y
0BF069 AD E9 F1 0B       		mv	[MML_data_adr],y	; Save MML data write address
0BF06D 0D E2 F1 0B       		mv	y,not_data		; Terminator data address -> Y
0BF071 AD 49 F5 0B       		mv	[!part3+!data_s_adr],y	; Initialize part 3 data address to terminator
0BF075 AD 39 F5 0B       		mv	[!part2+!data_s_adr],y	; Initialize part 2 data address to terminator
0BF079 0D 57 F5 0B       		mv	y,!data_buff		; Data buffer address -> Y
0BF07D AD 29 F5 0B       		mv	[!part1+!data_s_adr],y	; Set part 1 data write destination
0BF081 30 CC 13 FF       		mv	(!oct_flg),0ffh		; Set octave flag to initial value (unused)
0BF085 90 24             		mv	a,[x++]			; Read first MML character and advance X
0BF087 60 0D             		cmp	a,!cr			; CR (string terminator)?
0BF089 18 92             		jrz	mml_conv_exit_c		; If CR, go to exit processing
0BF08B 60 22             		cmp	a,'"'			; Double quote '"'?
0BF08D 18 02             		jrz	mml_conv_lp		; If quote, skip it and go to loop
0BF08F 7C 04             		dec	x			; Not a quote, back X up by 1
0BF091                   	mml_conv_lp:
0BF091                   		; --- Main parsing loop ---
0BF091 60 0D             		cmp	a,!cr			; CR?
0BF093 18 88             		jrz	mml_conv_exit_c		; If CR, go to exit processing
0BF095 60 3A             		cmp	a,':'			; ':' ? (part separator)
0BF097 18 B1             		jrz	part_ch			; Go to part change processing
0BF099 60 3E             		cmp	a,'>'			; '>' ? (octave up)
0BF09B 14 C2 F1          		jpz	oct_up			; Go to octave +1 processing
0BF09E 60 3C             		cmp	a,'<'			; '<' ? (octave down)
0BF0A0 14 CD F1          		jpz	oct_dw			; Go to octave -1 processing
0BF0A3 60 4F             		cmp	a,'O'			; 'O' ? (octave specification)
0BF0A5 14 AB F1          		jpz	oct_ch			; Go to octave change processing
0BF0A8 60 54             		cmp	a,'T'			; 'T' ? (tempo specification)
0BF0AA 18 DA             		jrz	temp2_ch		; Go to tempo change processing
0BF0AC 60 4C             		cmp	a,'L'			; 'L' ? (default length specification)
0BF0AE 18 74             		jrz	len_ch			; Go to note length change processing
0BF0B0 60 52             		cmp	a,'R'			; 'R' ? (rest)
0BF0B2 18 65             		jrz	kyuufu			; Go to rest processing
0BF0B4 60 2B             		cmp	a,'+'			; '+' ? (semitone up)
0BF0B6 14 BE F1          		jpz	oct_1up			; Go to temporary octave +1
0BF0B9 60 2D             		cmp	a,'-'			; '-' ? (semitone down)
0BF0BB 14 C9 F1          		jpz	oct_1dw			; Go to temporary octave -1
0BF0BE 60 49             		cmp	a,'I'			; 'I' ? (format specification)
0BF0C0 18 7A             		jrz	format_ch		; Go to format change processing
0BF0C2                   	; --- Note data setup ---
0BF0C2                   	; A: note name character (A-G or #A-#G)
0BF0C2 2D                	onp_set:	pushu	y		; Save Y register
0BF0C3 0D D4 F1 0B       		mv	y,mml_data1		; Standard note table start address -> Y
0BF0C7 60 23             		cmp	a,'#'			; Sharp '#'?
0BF0C9 18 06             		jrz	onp_skip		; If sharp, go to onp_skip (Y unchanged)
0BF0CB 0D DB F1 0B       		mv	y,mml_data2		; Sharp note table start address -> Y
0BF0CF 90 24             		mv	a,[x++]			; Read next character (note name)
0BF0D1 48 41             	onp_skip:	sub	a,'A'		; Calculate relative index from 'A'
0BF0D3 60 07             		cmp	a,7			; In range 0-6 (A-G)?
0BF0D5 1E 3F             		jrnc	onp_skip2		; Out of range, skip note processing
0BF0D7 45 50             		add	y,a			; Add note name offset to table address
0BF0D9 90 05             		mv	a,[y]			; Fetch note code
0BF0DB FD 10             		mv	il,a			; Set note code in IL register
0BF0DD 3D                		popu	y			; Restore Y register
0BF0DE 90 24             	onp_len:	mv	a,[x++]		; Read next character (length digit)
0BF0E0 48 30             		sub	a,'0'			; Convert ASCII digit to binary
0BF0E2 60 0A             		cmp	a,10			; In range 0-9?
0BF0E4 1C 0F             		jrc	onp_len_sk2		; If digit, go to length setup
0BF0E6 48 25             		sub	a,'U'-'0'		; Convert extended character code
0BF0E8 60 06             		cmp	a,6			; Range check
0BF0EA 1E 04             		jrnc	onp_len_sk		; Out of range, use default length
0BF0EC 40 0A             		add	a,10			; Convert to extended length value (10-15)
0BF0EE 12 05             		jr	onp_len_sk2		; Go to length setup
0BF0F0 30 80 33          	onp_len_sk:	mv	a,(!length_adr)	; Default length pointer -> A
0BF0F3 7C 04             		dec	x			; Back X up by 1 (no explicit length)
0BF0F5 28                	onp_len_sk2:	pushu	a		; Save A (length value) onto stack
0BF0F6 88 EC F1 0B       		mv	a,[format_data]		; Read format flag
0BF0FA 60 00             		cmp	a,0			; Format = 0?
0BF0FC 38                		popu	a			; Restore A
0BF0FD 18 03             		jrz	onp_len_sk3		; If format=0, do not update default length
0BF0FF 30 A0 33          		mv	(!length_adr),a		; Update default note length
0BF102 46 01             	onp_len_sk3:	add	a,il		; Combine length + note code
0BF104 B0 25             		mv	[y++],a			; Write to data buffer and advance Y
0BF106 30 61 13 10       		cmp	(!oct_flg),010h		; Octave flag already set (>=10h)?
0BF10A 02 91 F0          		jp	mml_conv_lp		; If set, go to main loop
0BF10D 30 80 13          		mv	a,(!oct_flg)		; Fetch temporary octave flag value
0BF110 30 CC 13 FF       		mv	(!oct_flg),0ffh		; Reset flag
0BF114 12 99             		jr	oct_ch_s		; Go to octave setting processing
0BF116 3D                	onp_skip2:	popu	y		; Restore Y register
0BF117 13 88             		jr	mml_conv_lp		; Return to main loop
0BF119                   	; --- Rest processing ---
0BF119 09 00             	kyuufu:		mv	il,0		; Note code = 0 (rest)
0BF11B 13 3F             		jr	onp_len			; Go to length processing
0BF11D                   	; --- MML parsing termination ---
0BF11D 7C 04             	mml_conv_exit_c:dec	x		; Back X up by 1 (return to CR position)
0BF11F 08 FF             	mml_conv_exit:	mv	a,0ffh		; End marker 0FFh
0BF121 B0 25             		mv	[y++],a			; Write end marker to data buffer
0BF123 06                		ret				; Return
0BF124                   	; --- Default note length change ('L' command) ---
0BF124 90 04             	len_ch:		mv	a,[x]		; Read character at current position
0BF126 48 30             		sub	a,'0'			; ASCII to binary conversion
0BF128 60 0A             		cmp	a,0ah			; In range 0-9?
0BF12A 1C 09             		jrc	len_sk			; If digit, go to length setting
0BF12C 48 55             		sub	a,'U'			; Extended character conversion
0BF12E 60 06             		cmp	a,6			; Range check
0BF130 02 91 F0          		jp	mml_conv_lp		; Out of range, skip
0BF133 40 0A             		add	a,10			; Extended value conversion
0BF135 30 A0 33          	len_sk:		mv	(!length_adr),a	; Update default note length
0BF138 6C 04             		inc	x			; Advance X to next character
0BF13A 13 AB             		jr	mml_conv_lp		; Return to main loop
0BF13C                   	; --- Format specification processing ('I' command) ---
0BF13C 90 04             	format_ch:	mv	a,[x]		; Read character at current position
0BF13E 48 30             		sub	a,'0'			; ASCII to binary conversion
0BF140 1C 04             		jrc	format_sk		; Not a digit, skip
0BF142 A8 EC F1 0B       		mv	[format_data],a		; Update format flag
0BF146 6C 04             	format_sk:	inc	x		; Advance X to next character
0BF148 13 B9             		jr	mml_conv_lp		; Return to main loop
0BF14A                   	; --- Part change processing (':' command) ---
0BF14A                   	; Terminates current part data and sets the write address for the next part
0BF14A 2C                	part_ch:	pushu	x		; Save X register
0BF14B 08 FF             		mv	a,0ffh			; End marker
0BF14D B0 25             		mv	[y++],a			; Terminate current part data buffer
0BF14F 8C E9 F1 0B       		mv	x,[MML_data_adr]	; Fetch MML data address table pointer
0BF153 0A 10 00          		mv	ba,16			; Next part struct offset = 16
0BF156 45 42             		add	x,ba			; Advance to next part structure address
0BF158 AC E9 F1 0B       		mv	[MML_data_adr],x	; Update MML data address pointer
0BF15C B5 04             		mv	[x],y			; Store data write destination in next part struct
0BF15E 30 84 30          		mv	x,(!octerve_adr)	; Fetch octave pointer
0BF161 6C 04             		inc	x			; Advance to next part octave storage address
0BF163 6C 04             		inc	x
0BF165 30 A4 30          		mv	(!octerve_adr),x	; Update octave pointer
0BF168 30 84 33          		mv	x,(!length_adr)		; Fetch length pointer
0BF16B 6C 04             		inc	x			; Advance to next part length storage address
0BF16D 6C 04             		inc	x
0BF16F 30 A4 33          		mv	(!length_adr),x		; Update length pointer
0BF172 3C                		popu	x			; Restore X register
0BF173 13 E4             		jr	mml_conv_lp		; Return to main loop
0BF175                   	; --- Tempo setting processing (direct value, inside mml_conv) ---
0BF175 90 04             	temp_ch:	mv	a,[x]		; Read character at current position
0BF177 48 30             		sub	a,30h			; ASCII to binary conversion
0BF179 60 0A             		cmp	a,0ah			; In range 0-9?
0BF17B 02 91 F0          		jp	mml_conv_lp		; Out of range, skip
0BF17E 40 D0             		add	a,0d0h			; Convert to tempo internal code
0BF180 B0 25             		mv	[y++],a			; Write tempo code to data buffer
0BF182 6C 04             		inc	x			; Advance X to next character
0BF184 13 F5             		jr	mml_conv_lp		; Return to main loop
0BF186                   	; --- Tempo setting processing ('T' command, multi-digit value) ---
0BF186 09 00             	temp2_ch:	mv	il,0		; Clear tempo accumulator
0BF188 08 DF             		mv	a,0dfh			; Tempo control code 0DFh
0BF18A B0 25             		mv	[y++],a			; Write code to data buffer
0BF18C 90 04             	temp2_lp1:	mv	a,[x]		; Read character at current position
0BF18E 48 30             		sub	a,30h			; ASCII to binary conversion
0BF190 60 0A             		cmp	a,10			; In range 0-9?
0BF192 1E 12             		jrnc	temp2_sk1		; Not a digit, end loop
0BF194 28                		pushu	a			; Save digit value
0BF195 FD 01             		mv	a,il			; Current accumulator -> A
0BF197 46 00             		add	a,a			; A * 2
0BF199 46 00             		add	a,a			; A * 4
0BF19B 46 10             		add	il,a			; IL = IL + A*4 (= IL*5)
0BF19D 46 11             		add	il,il			; IL = IL * 2 (= IL*10)
0BF19F 38                		popu	a			; Restore digit value
0BF1A0 46 10             		add	il,a			; IL = IL * 10 + digit
0BF1A2 6C 04             		inc	x			; Advance X to next character
0BF1A4 13 1A             		jr	temp2_lp1		; Process next digit
0BF1A6 B1 25             	temp2_sk1:	mv	[y++],il	; Write final tempo value to data buffer
0BF1A8 02 91 F0          		jp	mml_conv_lp		; Return to main loop
0BF1AB                   	; --- Octave change processing ('O' command) ---
0BF1AB 90 24             	oct_ch:		mv	a,[x++]		; Read octave digit and advance X
0BF1AD 48 30             		sub	a,30h			; ASCII to binary conversion
0BF1AF 60 0A             	oct_ch_s:	cmp	a,10		; In range 0-9?
0BF1B1 02 91 F0          		jp	mml_conv_lp		; Out of range, skip
0BF1B4 30 A0 30          		mv	(!octerve_adr),a	; Update octave value
0BF1B7 40 E0             		add	a,0e0h			; Convert to octave control code (0E0h-0E9h)
0BF1B9 B0 25             		mv	[y++],a			; Write octave code to data buffer
0BF1BB 02 91 F0          		jp	mml_conv_lp		; Return to main loop
0BF1BE                   	; --- Temporary octave +1 ('+' command) ---
0BF1BE 32 C8 13 30       	oct_1up:	mv	(!oct_flg),(!octerve_adr) ; Save current octave to flag
0BF1C2 30 80 30          	oct_up:		mv	a,(!octerve_adr); Fetch current octave value
0BF1C5 6C 00             		inc	a			; Octave + 1
0BF1C7 13 1A             		jr	oct_ch_s		; Go to octave setting processing
0BF1C9                   	; --- Temporary octave -1 ('-' command) ---
0BF1C9 32 C8 13 30       	oct_1dw:	mv	(!oct_flg),(!octerve_adr) ; Save current octave to flag
0BF1CD 30 80 30          	oct_dw:		mv	a,(!octerve_adr); Fetch current octave value
0BF1D0 7C 00             		dec	a			; Octave - 1
0BF1D2 13 25             		jr	oct_ch_s		; Go to octave setting processing
0BF1D4                   	; ============================================================
0BF1D4                   	; Note code table
0BF1D4                   	; mml_data1: Standard notes (C D E F G A B and rest)
0BF1D4                   	; mml_data2: Sharp notes (#C #D #F #G #A)
0BF1D4                   	; ============================================================
0BF1D4 A0                	mml_data1:	db	0a0h		; A
0BF1D5 C0                		db	0c0h		; B
0BF1D6 10                		db	010h		; C
0BF1D7 30                		db	030h		; D
0BF1D8 50                		db	050h		; E
0BF1D9 60                		db	060h		; F
0BF1DA 80                		db	080h		; G
0BF1DB B0                	mml_data2:	db	0b0h		; #A
0BF1DC 10                		db	010h		; #B -> equivalent to C
0BF1DD 20                		db	020h		; #C
0BF1DE 40                		db	040h		; #D
0BF1DF 50                		db	050h		; #E -> equivalent to F
0BF1E0 70                		db	070h		; #F
0BF1E1 90                		db	090h		; #G
0BF1E2                   	; --- Terminator data / default initial values ---
0BF1E2 FF                	not_data:	db	0ffh		; End marker (when part is unused)
0BF1E3 03                	octerve:	db	3		; Default octave value (part 1)
0BF1E4 05                	length:		db	5		; Default note length value (part 1)
0BF1E5 03                	octerve2:	db	3		; Default octave value (part 2)
0BF1E6 05                	length2:	db	5		; Default note length value (part 2)
