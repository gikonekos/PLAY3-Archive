0BF025 07                		retf				; ファー・リターン
0BF026                   	; ============================================================
0BF026                   	; BASICコマンドテーブル定義
0BF026                   	; PLAY コマンドと EXOFF コマンドを登録する
0BF026                   	; ============================================================
0BF026 04                	basic_command:	db	04h		; 命令文字数 (4文字)
0BF027 50 4C 41 59       		dm	'PLAY'			; コマンド名文字列
0BF02B 1F                		db	1fh			; 中間コード
0BF02C 05                		db	5			; 次コマンド文字数 (5文字)
0BF02D 45 58 4F 46 46    		dm	'EXOFF'			; コマンド名文字列
0BF032 02                		db	2			; コード長
0BF033 00 00             		db	0,0			; ターミネータ
0BF035 1F                	basic_code:	db	1fh		; コードフラグ
0BF036 3F F0             		dw	!entry			; PLAYコマンド処理ルーチンアドレス
0BF038 8B                		db	8bh			; 属性バイト (bit6=1, bit7=1)
0BF039 02                		db	2			; コード長
0BF03A 13 F0             		dw	remove			; EXOFFコマンド処理ルーチンアドレス
0BF03C 8B                		db	8bh			; 属性バイト
0BF03D 00 00             		db	0,0			; ターミネータ
0BF03F                   		endl				; ローカルスコープ終了
0BF03F                   	; ============================================================
0BF03F                   	; entry - PLAYコマンドエントリポイント
0BF03F                   	; 割り込みを無効化し、MML解析・再生を実行して復元する
0BF03F                   	; ============================================================
0BF03F                   	entry:		local			; ローカルスコープ開始
