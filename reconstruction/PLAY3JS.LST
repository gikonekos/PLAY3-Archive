0BF000                   	; install / remove - BASICコマンド組み込み・解除
0BF000                   	; ============================================================
0BF000                   	install:	local			; ローカルスコープ開始
0BF000 0C 26 F0 0B       		mv	x,basic_command		; コマンドテーブル先頭アドレス -> X
